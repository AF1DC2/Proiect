DB_HOST=127.0.0.1
DB_NAME=carcassonne_api
DB_USER=root
DB_PASS=

# Frontend origin allowed by CORS (the Vite dev server, or your prod domain)
FRONTEND_URL=http://localhost:5173

# Pusher credentials (from https://dashboard.pusher.com)
PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=eu
